---
import { Image } from "astro:assets";
import ReviewComponent from "@components/ui/blocks/ReviewComponent.astro";
import type { ImageMetadata } from "astro";

const {
  title,
  headline,
  subTitle,
  primaryBtn,
  primaryBtnURL,
  secondaryBtn,
  secondaryBtnURL,
  withReview,
  avatars,
  starCount,
  rating,
  reviews,
  src,
  alt,
  trustItems = ["Founder-led", "No handoffs", "SEO-ready"],
  containedByHeroBand = false,
} = Astro.props;

interface Headline {
  before: string;
  accent: string;
  after: string;
}

interface Props {
  title?: string;
  headline?: Headline;
  subTitle?: string;
  primaryBtn?: string;
  primaryBtnURL?: string;
  secondaryBtn?: string;
  secondaryBtnURL?: string;
  withReview?: boolean;
  avatars?: Array<string>;
  starCount?: number;
  rating?: string;
  reviews?: string;
  src?: ImageMetadata;
  alt?: string;
  badgeLabel?: string;
  trustItems?: string[];
  containedByHeroBand?: boolean;
}

const sectionClass = containedByHeroBand
  ? "relative flex flex-1 items-center overflow-hidden px-4 pb-14 pt-10 text-white sm:px-6 sm:pb-16 sm:pt-12 lg:px-8 lg:pb-20 lg:pt-16"
  : "relative overflow-hidden bg-blue-900 px-4 py-14 text-white sm:px-6 lg:px-8 lg:py-20";
---

<section data-hero class={sectionClass}>
  <!-- Subtle grid pattern overlay -->
  <div
    class="pointer-events-none absolute inset-0 opacity-[0.02]"
    style="background-image: radial-gradient(circle, rgba(255,255,255,0.8) 1px, transparent 1px); background-size: 32px 32px;"
    aria-hidden="true"
  >
  </div>

  <div
    class="relative mx-auto grid max-w-[85rem] gap-10 lg:grid-cols-[minmax(0,1.1fr)_minmax(320px,0.9fr)] lg:items-center lg:gap-16"
  >
    <div class="min-w-0">
      <h1
        data-hero-title
        class="max-w-4xl text-pretty text-4xl font-bold leading-tight tracking-tight text-white sm:text-5xl md:text-6xl lg:text-7xl lg:leading-[1.04]"
      >
        {
          headline ? (
            <>
              <span data-hero-phrase>{headline.before}</span>
              <span
                data-hero-accent
                data-hero-phrase
                class="relative inline-block max-w-full whitespace-nowrap text-yellow-400"
              >
                {headline.accent}
                <span class="absolute -bottom-1 left-0 h-[3px] w-full rounded-full bg-yellow-400/40" />
              </span>
              <span data-hero-phrase>{headline.after}</span>
            </>
          ) : (
            <Fragment set:html={title ?? ""} />
          )
        }
      </h1>

      {
        subTitle && (
          <p
            data-hero-subtitle
            class="mt-6 max-w-2xl text-lg leading-8 text-blue-100/80 sm:text-xl sm:leading-8"
          >
            {subTitle}
          </p>
        )
      }

      <div class="mt-9 flex flex-col gap-3 sm:flex-row">
        {
          primaryBtn && (
            <a
              href={primaryBtnURL}
              class="group relative inline-flex w-full items-center justify-center gap-x-2 overflow-hidden rounded-xl bg-yellow-400 px-7 py-4 text-sm font-bold text-blue-900 shadow-lg shadow-yellow-400/20 transition-all duration-300 hover:bg-yellow-300 hover:shadow-xl hover:shadow-yellow-400/30 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-yellow-400 focus-visible:ring-offset-2 focus-visible:ring-offset-blue-900 sm:w-auto"
            >
              <span class="min-w-0 text-center leading-snug">{primaryBtn}</span>
              <svg
                class="size-4 flex-shrink-0 transition duration-300 group-hover:translate-x-1"
                width="24"
                height="24"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2.5"
                stroke-linecap="round"
                stroke-linejoin="round"
                aria-hidden="true"
              >
                <path d="m9 18 6-6-6-6" />
              </svg>
            </a>
          )
        }
        {
          secondaryBtn && (
            <a
              href={secondaryBtnURL}
              class="inline-flex w-full items-center justify-center rounded-xl border border-white/20 bg-white/[0.07] px-7 py-4 text-sm font-bold text-white backdrop-blur-md transition-all duration-300 hover:border-white/30 hover:bg-white/[0.12] sm:w-auto"
            >
              {secondaryBtn}
            </a>
          )
        }
      </div>

      <div
        class="mt-8 flex flex-wrap items-center gap-x-6 gap-y-3"
      >
        {
          trustItems.map((item) => (
            <div class="flex items-center gap-2 rounded-full border border-white/10 bg-white/[0.05] px-3.5 py-1.5 text-sm font-semibold text-blue-100/90 backdrop-blur-sm">
              <svg
                class="size-3.5 flex-shrink-0 text-yellow-400"
                fill="currentColor"
                viewBox="0 0 20 20"
                aria-hidden="true"
              >
                <path
                  fill-rule="evenodd"
                  d="M16.704 4.153a.75.75 0 01.143 1.052l-8 10.5a.75.75 0 01-1.127.075l-4.5-4.5a.75.75 0 011.06-1.06l3.894 3.893 7.48-9.817a.75.75 0 011.05-.143z"
                  clip-rule="evenodd"
                />
              </svg>
              <span>{item}</span>
            </div>
          ))
        }
      </div>

      {
        withReview && (
          <div class="mt-8">
            <ReviewComponent
              avatars={avatars}
              starCount={starCount}
              rating={rating}
              reviews={reviews}
            />
          </div>
        )
      }
    </div>

    <div data-hero-image class="min-w-0">
      {
        src && alt && (
          <div class="relative mx-auto max-w-md lg:max-w-none">
            {/* Glow behind the image */}
            <div class="absolute inset-0 scale-105 rounded-2xl bg-gradient-to-br from-blue-500/20 via-transparent to-yellow-400/10 blur-2xl" aria-hidden="true" />
            <div class="absolute inset-x-6 bottom-0 top-14 rounded-2xl bg-blue-700/15" />
            <div class="hero-image-float relative overflow-hidden rounded-2xl border border-white/15 bg-white/[0.07] p-4 shadow-2xl shadow-blue-900/40 backdrop-blur-sm ring-1 ring-white/10">
              <Image
                src={src}
                alt={alt}
                class="h-full w-full rounded-lg object-contain object-center"
                draggable={"false"}
                loading={"eager"}
                format={"avif"}
                width={920}
                sizes="(min-width: 1024px) 430px, (min-width: 768px) 48vw, 90vw"
                fetchpriority="high"
              />
            </div>
          </div>
        )
      }
    </div>
  </div>
</section>

<style>
  [data-hero-title] :global(.text-blue-600),
  [data-hero-title] :global(.dark\:text-blue-300) {
    color: #fde047 !important;
  }

  [data-hero-phrase] {
    display: inline;
  }

  :global(html[lang="ja"]) [data-hero-title] {
    line-height: 1.12;
    text-wrap: balance;
  }

  :global(html[lang="ja"]) [data-hero-phrase] {
    display: inline-block;
    line-height: inherit;
    max-width: 100%;
    vertical-align: baseline;
    word-break: keep-all;
  }

  :global(html[lang="ja"]) [data-hero-accent] {
    white-space: normal;
  }

  .hero-image-float {
    animation: hero-float 6s ease-in-out infinite;
  }

  @keyframes hero-float {
    0%, 100% { transform: translateY(0px); }
    50% { transform: translateY(-12px); }
  }

  @media (prefers-reduced-motion: reduce) {
    .hero-image-float {
      animation: none;
    }
  }
</style>
