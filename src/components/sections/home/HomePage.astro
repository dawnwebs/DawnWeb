---
import { Image } from "astro:assets";
import MainLayout from "@/layouts/MainLayout.astro";
import HeroSection from "@components/sections/landing/HeroSection.astro";
import FAQ from "@components/sections/misc/FAQ.astro";
import AnnouncementBanner from "@components/ui/banners/AnnouncementBanner.astro";
import PrimaryCTA from "@components/ui/buttons/PrimaryCTA.astro";
import { SITE } from "@data/constants";
import type { HomeContent } from "@data/home";
import {
  buildFaqSchema,
  buildWebPageSchema,
  buildWebSiteSchema,
} from "@utils/seo";

import serviceImage1 from "@images/services/web-design.jpg";
import serviceImage2 from "@images/services/web-dev.jpg";
import serviceImage3 from "@images/services/code.jpg";
import serviceImage4 from "@images/services/software.jpg";

const serviceImages = [serviceImage1, serviceImage2, serviceImage3, serviceImage4];

const { content, faqs } = Astro.props;

interface FaqGroup {
  subTitle?: string;
  faqs: Array<{
    question: string;
    answer: string;
  }>;
}

interface Props {
  content: HomeContent;
  faqs: FaqGroup;
}

const structuredData = [
  buildWebSiteSchema(SITE.url),
  buildWebPageSchema({
    title: content.pageTitle,
    description: content.pageDescription,
    pathname: content.pathname,
    locale: content.locale,
    siteUrl: SITE.url,
  }),
  buildFaqSchema({ faqs: faqs.faqs }),
];
---

<MainLayout
  title={content.pageTitle}
  meta={content.pageDescription}
  lang={content.lang}
  structuredData={structuredData}
>
  <HeroSection
    slot="hero"
    headline={content.hero.headline}
    subTitle={content.hero.subTitle}
    primaryBtn={content.primaryCta}
    primaryBtnURL={content.contactUrl}
    withReview={false}
    src={content.hero.image}
    alt={content.hero.imageAlt}
    badgeLabel={content.hero.badgeLabel}
    trustItems={content.hero.trustItems}
    containedByHeroBand={true}
  />

  <AnnouncementBanner
    btnId={`home-audit-banner-${content.locale}`}
    badge={content.announcement.badge}
    title={content.announcement.title}
    description={content.announcement.description}
    btnTitle={content.primaryCta}
    url={content.contactUrl}
    storageKey={`dawnweb-home-audit-banner-${content.locale}`}
    variant="fixed"
  />

  <!-- 2. Proof Points - Marquee/Strip style -->
  <section class="relative overflow-hidden bg-white py-12 dark:bg-neutral-900 sm:py-16">
    <div class="pointer-events-none absolute inset-0 bg-gradient-to-b from-transparent to-neutral-50/50 dark:to-neutral-950/50"></div>
    <div class="mx-auto max-w-[85rem] px-4 sm:px-6 lg:px-8">
      <div class="grid gap-8 md:grid-cols-3 md:gap-12">
        {content.proof.map((point) => (
          <article class="group relative flex flex-col justify-between overflow-hidden rounded-2xl bg-neutral-50 p-8 shadow-sm transition-all duration-300 hover:-translate-y-1 hover:shadow-md dark:bg-neutral-800/50">
            <div class="absolute bottom-0 left-0 h-1 w-0 bg-yellow-400 transition-all duration-500 group-hover:w-full"></div>
            <div>
              <div class="flex items-center justify-between">
                <span class="text-5xl font-black text-neutral-200 dark:text-neutral-700 transition-colors duration-300 group-hover:text-blue-600/20 dark:group-hover:text-blue-400/20">
                  {point.label}
                </span>
                <div class="flex h-10 w-10 items-center justify-center rounded-full bg-white text-blue-600 shadow-sm dark:bg-neutral-800 dark:text-blue-400">
                  <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                  </svg>
                </div>
              </div>
              <h3 class="mt-6 text-2xl font-bold tracking-tight text-neutral-950 dark:text-white">
                {point.title}
              </h3>
              <p class="mt-3 text-base leading-relaxed text-neutral-600 dark:text-neutral-300">
                {point.description}
              </p>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- 3. Services - Dark Bento Grid -->
  <section class="bg-neutral-950 py-16 sm:py-24" data-reveal>
    <div class="mx-auto max-w-[85rem] px-4 sm:px-6 lg:px-8">
      <div class="mb-12 max-w-3xl">
        <p class="text-sm font-bold uppercase tracking-wider text-yellow-400">
          {content.services.eyebrow}
        </p>
        <h2 class="mt-3 text-3xl font-bold tracking-tight text-white sm:text-4xl md:text-5xl md:leading-tight">
          {content.services.title}
        </h2>
        <p class="mt-5 text-lg text-neutral-400">
          {content.services.description}
        </p>
      </div>

      <div class="grid gap-6 md:grid-cols-3">
        {content.services.items.map((service, index) => {
          const isWide = index === 0 || index === 3;
          return (
            <a
              href={service.href}
              class={`group relative overflow-hidden rounded-3xl p-8 transition-all duration-300 hover:-translate-y-1 hover:shadow-2xl hover:shadow-blue-900/20 flex flex-col justify-end min-h-[320px] ${
                index === 0
                  ? "md:col-span-2 border border-blue-800/50"
                  : index === 3
                  ? "md:col-span-2 border border-neutral-700/50 hover:border-neutral-600"
                  : "border border-neutral-800 hover:border-neutral-700"
              }`}
            >
              <!-- Full Card Background Image -->
              <div class="absolute inset-0 z-0">
                <Image src={serviceImages[index]} alt={service.title} class="h-full w-full object-cover opacity-40 transition-transform duration-700 group-hover:scale-110 group-hover:opacity-70" />
                <div class="absolute inset-0 bg-gradient-to-t from-neutral-950 via-neutral-900/80 to-transparent"></div>
              </div>
              
              <!-- Hover Arrow -->
              <div class="absolute right-8 top-8 opacity-0 transition-all duration-300 group-hover:opacity-100 group-hover:translate-x-1 z-10">
                <svg class={`h-6 w-6 ${isWide ? 'text-yellow-400' : 'text-blue-400'}`} fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
                </svg>
              </div>

              <!-- Text Content -->
              <div class="relative z-10 mt-auto">
                <h3 class={`font-bold tracking-tight text-white ${isWide ? 'text-3xl sm:text-4xl' : 'text-2xl'}`}>
                  {service.title}
                </h3>
                <p class={`mt-4 text-neutral-300 ${isWide ? 'text-lg max-w-md' : 'text-base'}`}>
                  {service.description}
                </p>
              </div>
            </a>
          );
        })}
      </div>
    </div>
  </section>

  <!-- 4. Founder Section - Split Panel with Personality -->
  <section class="relative overflow-hidden bg-blue-900 py-16 sm:py-24" data-reveal>
    <div class="absolute inset-0 bg-[url('/patterns/grid.svg')] opacity-10"></div>
    <div class="mx-auto grid max-w-[85rem] gap-12 px-4 sm:px-6 lg:grid-cols-2 lg:items-center lg:px-8">
      <div class="relative">
        <div class="absolute -left-8 -top-8 text-9xl text-blue-800/50 font-serif leading-none" aria-hidden="true">&ldquo;</div>
        <div class="relative z-10">
          <p class="text-sm font-bold uppercase tracking-wider text-yellow-400">
            {content.founder.eyebrow}
          </p>
          <h2 class="mt-4 text-3xl font-bold tracking-tight text-white sm:text-4xl md:text-5xl md:leading-tight">
            {content.founder.title}
          </h2>
          <p class="mt-6 text-xl leading-relaxed text-blue-100">
            {content.founder.body}
          </p>
        </div>
      </div>
      
      <div class="relative lg:ml-auto lg:w-full lg:max-w-md">
        <div class="relative flex flex-col gap-4">
          {content.founder.points.map((point) => (
            <div class="flex items-center gap-4 rounded-2xl border border-white/10 bg-white/5 p-5 backdrop-blur-md transition-colors hover:border-white/20 hover:bg-white/10">
              <div class="flex h-10 w-10 shrink-0 items-center justify-center rounded-full bg-yellow-400 text-blue-900">
                <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7" />
                </svg>
              </div>
              <span class="text-lg font-bold text-white">{point}</span>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- 5. Portfolio Section - Horizontal Carousel Style -->
  <section class="overflow-hidden bg-white py-16 dark:bg-[#0c1322] sm:py-24" data-reveal>
    <div class="mx-auto max-w-[85rem] px-4 sm:px-6 lg:px-8">
      <div class="flex flex-col gap-6 md:flex-row md:items-end md:justify-between">
        <div class="max-w-2xl">
          <p class="text-sm font-bold uppercase tracking-wider text-blue-600 dark:text-blue-400">
            {content.portfolio.eyebrow}
          </p>
          <h2 class="mt-3 text-3xl font-bold tracking-tight text-neutral-950 dark:text-white sm:text-4xl md:text-5xl md:leading-tight">
            {content.portfolio.title}
          </h2>
          <p class="mt-5 text-lg text-neutral-600 dark:text-neutral-400">
            {content.portfolio.description}
          </p>
        </div>
        <div class="flex flex-col items-end gap-4 shrink-0">
           <PrimaryCTA title={content.primaryCta} url={content.contactUrl} />
        </div>
      </div>

      <div class="mt-12 -mx-4 flex overflow-x-auto px-4 pb-12 sm:-mx-6 sm:px-6 lg:-mx-8 lg:px-8 snap-x snap-mandatory scrollbar-thin scrollbar-thumb-neutral-300 dark:scrollbar-thumb-neutral-700 scrollbar-track-transparent">
        <div class="flex gap-6 lg:gap-8">
          {content.portfolio.items.map((project) => (
            <a
              href={project.href}
              class="group relative flex w-80 shrink-0 snap-center flex-col overflow-hidden rounded-3xl bg-white shadow-lg transition-all duration-500 hover:shadow-xl dark:bg-neutral-900 sm:w-[400px]"
            >
              <div class="relative aspect-[4/3] overflow-hidden">
                <div class="absolute inset-0 z-10 bg-blue-900/0 transition-colors duration-500 group-hover:bg-blue-900/20"></div>
                <Image
                  src={project.image}
                  alt={project.imageAlt}
                  class="h-full w-full object-cover transition-transform duration-700 group-hover:scale-110"
                  loading="lazy"
                  width={600}
                />
              </div>
              <div class="flex flex-1 flex-col justify-between p-6 sm:p-8">
                <div>
                  <h3 class="text-2xl font-bold tracking-tight text-neutral-950 dark:text-white">
                    {project.title}
                  </h3>
                  <p class="mt-3 text-base text-neutral-600 dark:text-neutral-400">
                    {project.description}
                  </p>
                </div>
                <div class="mt-6 flex items-center text-sm font-bold text-blue-600 dark:text-blue-400">
                  <span class="relative">
                    {content.portfolio.actionLabel}
                    <span class="absolute -bottom-1 left-0 h-0.5 w-0 bg-blue-600 transition-all duration-300 group-hover:w-full dark:bg-blue-400"></span>
                  </span>
                  <svg class="ml-2 h-4 w-4 transition-transform duration-300 group-hover:translate-x-2" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
                  </svg>
                </div>
              </div>
            </a>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- 6. Process Section - Connected Timeline -->
  <section class="bg-white py-16 dark:bg-neutral-900 sm:py-24" data-reveal>
    <div class="mx-auto max-w-[85rem] px-4 sm:px-6 lg:px-8">
      <div class="mb-16 text-center">
        <p class="text-sm font-bold uppercase tracking-wider text-blue-600 dark:text-blue-400">
          {content.process.eyebrow}
        </p>
        <h2 class="mt-3 text-3xl font-bold tracking-tight text-neutral-950 dark:text-white sm:text-4xl md:text-5xl md:leading-tight">
          {content.process.title}
        </h2>
      </div>

      <div class="relative">
        <!-- Connecting Line -->
        <div class="absolute left-1/2 top-0 h-full w-0.5 -translate-x-1/2 bg-neutral-200 dark:bg-neutral-800 md:left-0 md:top-8 md:h-0.5 md:w-full md:translate-x-0"></div>
        
        <div class="relative grid gap-12 md:grid-cols-4 md:gap-6">
          {content.process.items.map((step, index) => (
            <div class="group relative flex flex-col items-center text-center md:items-start md:text-left">
              <div class="relative z-10 mb-6 flex h-16 w-16 items-center justify-center rounded-full border-4 border-white bg-blue-50 text-xl font-black text-blue-600 shadow-md transition-transform duration-300 group-hover:scale-110 dark:border-neutral-900 dark:bg-blue-900/30 dark:text-blue-400">
                {index + 1}
              </div>
              <h3 class="text-xl font-bold text-neutral-950 dark:text-white">
                {step.title}
              </h3>
              <p class="mt-3 text-base text-neutral-600 dark:text-neutral-400">
                {step.description}
              </p>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- 7. Trust Block - Full Bleed Impact -->
  <section class="bg-blue-600 px-4 py-20 text-center sm:px-6 lg:px-8 lg:py-32" data-reveal>
    <div class="mx-auto max-w-[85rem]">
      <p class="mb-6 text-sm font-bold uppercase tracking-wider text-blue-200">
        {content.trust.eyebrow}
      </p>
      <h2 class="text-4xl font-black tracking-tight text-white sm:text-5xl md:text-6xl lg:text-7xl">
        {content.trust.title}
        <span class="relative inline-block whitespace-nowrap text-yellow-400">
          {content.trust.accent}
          <span class="absolute -bottom-2 left-0 h-[3px] w-full rounded-full bg-yellow-400/40"></span>
        </span>.
      </h2>
      
      <div class="mx-auto mt-12 max-w-3xl rounded-3xl bg-white/10 p-8 backdrop-blur-md sm:p-10">
        <p class="text-xl font-medium leading-relaxed text-white sm:text-2xl">
          "{content.trust.description}"
        </p>
        <div class="mx-auto mt-8 h-1 w-12 rounded-full bg-yellow-400"></div>
        <p class="mt-6 text-base text-blue-100">
          {content.trust.note}
        </p>
      </div>
    </div>
  </section>

  <FAQ title={content.faqTitle} faqs={faqs} />

  <!-- 9. Final CTA - Glowing Mesh -->
  <section class="relative overflow-hidden bg-neutral-950 px-4 py-24 text-center sm:px-6 lg:px-8 lg:py-32" data-reveal>
    <div class="relative z-10 mx-auto max-w-4xl">
      <h2 class="text-4xl font-bold tracking-tight text-white sm:text-5xl md:text-6xl lg:leading-tight">
        {content.finalCta.title}
      </h2>
      <p class="mx-auto mt-6 max-w-2xl text-xl leading-relaxed text-neutral-300">
        {content.finalCta.description}
      </p>
      <div class="mt-10 flex justify-center">
        <div class="relative">
          <a
            href={content.contactUrl}
            class="relative inline-flex items-center justify-center gap-x-3 rounded-xl bg-yellow-400 px-8 py-5 text-lg font-bold text-blue-900 transition-transform duration-300 hover:scale-105"
          >
            {content.primaryCta}
            <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M14 5l7 7m0 0l-7 7m7-7H3" />
            </svg>
          </a>
        </div>
      </div>
    </div>
  </section>
</MainLayout>
